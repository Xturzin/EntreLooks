{
   "buildCommand": "sh build.sh",
   "outputDirectory": ".",
   "headers": [
      {
         "source": "/(.*)",
         "headers": [
            {
               "key": "X-Content-Type-Options",
               "value": "nosniff"
            },
            {
               "key": "X-Frame-Options",
               "value": "DENY"
            },
            {
               "key": "Referrer-Policy",
               "value": "strict-origin-when-cross-origin"
            }
         ]
      },
      {
         "source": "/index.html",
         "headers": [
            {
               "key": "Cache-Control",
               "value": "public, no-cache, must-revalidate"
            }
         ]
      },
      {
         "source": "/manifest.json",
         "headers": [
            {
               "key": "Cache-Control",
               "value": "public, max-age=86400"
            }
         ]
      },
      {
         "source": "/assets/(.*)",
         "headers": [
            {
               "key": "Cache-Control",
               "value": "public, max-age=604800"
            }
         ]
      },
      {
         "source": "/css/(.*)",
         "headers": [
            {
               "key": "Cache-Control",
               "value": "public, max-age=3600"
            }
         ]
      },
      {
         "source": "/js/(.*)",
         "headers": [
            {
               "key": "Cache-Control",
               "value": "public, max-age=3600"
            }
         ]
      }
   ]
}